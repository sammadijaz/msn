{
  "name": "@madsn/formatter",
  "version": "1.0.2",
  "description": "Auto-formatter for Mad Sam Notation (MSN) files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5"
  },
  "keywords": [
    "msn",
    "formatter",
    "format"
  ],
  "license": "MIT",
  "homepage": "https://msn.sammadijaz.me",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sammadijaz/msn.git",
    "directory": "packages/formatter"
  }
}
