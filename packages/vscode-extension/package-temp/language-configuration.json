{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "folding": {
    "markers": {
      "start": "^-\\s",
      "end": "^(?=-\\s)"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^-+\\s+\\w+\\s*$",
    "decreaseIndentPattern": "^$"
  },
  "wordPattern": "[\\w][\\w\\-]*"
}
